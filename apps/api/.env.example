# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/gon

# Auth
JWT_SECRET=change-me-in-production-at-least-32-chars
TOKEN_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# LLM
OPENAI_API_KEY=sk-your-openai-key

# Supabase (optional for now)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Billing
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# Frontend
FRONTEND_URL=http://localhost:3000
PORT=3001

# ── Platform OAuth Credentials ──

# X (Twitter) — https://developer.twitter.com
X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret
X_REDIRECT_URI=http://localhost:3000/integrations/callback

# Instagram (Meta Graph API) — https://developers.facebook.com
INSTAGRAM_CLIENT_ID=your-instagram-client-id
INSTAGRAM_CLIENT_SECRET=your-instagram-client-secret
INSTAGRAM_REDIRECT_URI=http://localhost:3000/integrations/callback

# TikTok — https://developers.tiktok.com
TIKTOK_CLIENT_ID=your-tiktok-client-id
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret
TIKTOK_REDIRECT_URI=http://localhost:3000/integrations/callback

# YouTube (Google Cloud Console) — https://console.cloud.google.com
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
YOUTUBE_REDIRECT_URI=http://localhost:3000/integrations/callback

# LinkedIn — https://developer.linkedin.com
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:3000/integrations/callback

# Threads (Meta) — https://developers.facebook.com
THREADS_CLIENT_ID=your-threads-client-id
THREADS_CLIENT_SECRET=your-threads-client-secret
THREADS_REDIRECT_URI=http://localhost:3000/integrations/callback
