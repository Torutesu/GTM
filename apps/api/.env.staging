# GON - Staging Environment
NODE_ENV=staging

# API
PORT=3001
API_URL=http://localhost:3001
FRONTEND_URL=https://gon-staging.vercel.app

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gon_staging

# JWT
JWT_SECRET=staging-gon-jwt-secret-change-in-production
REFRESH_TOKEN_SECRET=staging-gon-refresh-secret-change-in-production

# OpenAI
OPENAI_API_KEY=

# X (Twitter) OAuth
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=https://gon-staging.vercel.app/integrations/callback

# Instagram OAuth
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=https://gon-staging.vercel.app/integrations/callback
