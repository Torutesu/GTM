generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MEMBER
  VIEWER
}

enum PostStatus {
  DRAFT
  APPROVED
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
}

enum Platform {
  X
  INSTAGRAM
  TIKTOK
  YOUTUBE
  FACEBOOK
  LINKEDIN
}

enum IntegrationStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AgentType {
  GROWTH_STRATEGY
  SOCIAL_MEDIA
  COMPETITOR_INTELLIGENCE
  SOCIAL_LISTENING
  SEO_GEO
  INDUSTRY_NEWS
  OUTREACH
  CVR_OPTIMIZATION
}

enum ViolationSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ViolationStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  DISMISSED
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  plan      String   @default("free")
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  users            User[]
  integrationAccounts IntegrationAccount[]
  posts            Post[]
  campaigns        Campaign[]
  tasks            Task[]
  generationLogs   GenerationLog[]
  feedEvents       FeedEvent[]
  policyViolations PolicyViolation[]
  auditLogs        AuditLog[]

  @@map("tenants")
}

model User {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  email     String   @unique
  name      String
  password  String?
  role      UserRole @default(MEMBER)
  settings  Json     @default("{}")
  country   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  integrationAccounts IntegrationAccount[]
  assignedTasks      Task[]              @relation("assignedTasks")
  generationLogs     GenerationLog[]
  policyViolations   PolicyViolation[]

  @@map("users")
}

model IntegrationAccount {
  id               String            @id @default(uuid())
  tenantId         String            @map("tenant_id")
  userId           String            @map("user_id")
  platform         Platform
  platformUserId   String?           @map("platform_user_id")
  platformUserName String?           @map("platform_user_name")
  accessToken      String            @map("access_token")
  refreshToken     String?           @map("refresh_token")
  scope            String[]
  tokenExpiresAt   DateTime?         @map("token_expires_at")
  connectedAt      DateTime          @default(now()) @map("connected_at")
  lastSyncedAt     DateTime?         @map("last_synced_at")
  status           IntegrationStatus @default(ACTIVE)
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  deletedAt        DateTime?         @map("deleted_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
  posts  Post[]

  @@map("integration_accounts")
}

model Post {
  id                   String     @id @default(uuid())
  tenantId             String     @map("tenant_id")
  integrationAccountId String?    @map("integration_account_id")
  campaignId           String?    @map("campaign_id")
  platform             Platform
  contentText          String     @map("content_text")
  mediaUrls            String[]   @map("media_urls")
  scheduledAt          DateTime?  @map("scheduled_at")
  postedAt             DateTime?  @map("posted_at")
  status               PostStatus @default(DRAFT)
  platformPostId       String?    @map("platform_post_id")
  platformPostUrl      String?    @map("platform_post_url")
  engagementMetrics    Json       @default("{}") @map("engagement_metrics")
  isAiGenerated        Boolean    @default(false) @map("is_ai_generated")
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")
  deletedAt            DateTime?  @map("deleted_at")

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  integrationAccount IntegrationAccount?  @relation(fields: [integrationAccountId], references: [id])
  campaign           Campaign?           @relation(fields: [campaignId], references: [id])

  @@map("posts")
}

model Campaign {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  goal        String?
  kpiTargets  Json     @default("{}") @map("kpi_targets")
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  budget      Float?
  status      String   @default("planning")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  posts  Post[]
  tasks  Task[]

  @@map("campaigns")
}

model Task {
  id               String     @id @default(uuid())
  tenantId         String     @map("tenant_id")
  campaignId       String?    @map("campaign_id")
  assignedUserId   String?    @map("assigned_user_id")
  agentType        AgentType
  title            String
  description      String?
  status           TaskStatus @default(PENDING)
  priority         String     @default("medium")
  parentTaskId     String?    @map("parent_task_id")
  dueDate          DateTime?  @map("due_date")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  deletedAt        DateTime?  @map("deleted_at")

  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  assignedTo User?     @relation("assignedTasks", fields: [assignedUserId], references: [id])

  @@map("tasks")
}

model GenerationLog {
  id               String     @id @default(uuid())
  tenantId         String     @map("tenant_id")
  userId           String     @map("user_id")
  sessionId        String?    @map("session_id")
  providerId       String     @map("provider_id")
  modelName        String?    @map("model_name")
  promptHash       String?    @map("prompt_hash")
  outputId         String?    @map("output_id")
  agentName        String?    @map("agent_name")
  featureName      String?    @map("feature_name")
  inputTokens      Int?       @map("input_tokens")
  outputTokens     Int?       @map("output_tokens")
  latencyMs        Int?       @map("latency_ms")
  policyCheckResult String?   @map("policy_check_result")
  createdAt        DateTime   @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@map("generation_logs")
}

model PolicyViolation {
  id            String            @id @default(uuid())
  tenantId      String            @map("tenant_id")
  userId        String            @map("user_id")
  violationType String            @map("violation_type")
  severity      ViolationSeverity
  description   String?
  source        String?
  actionTaken   String?           @map("action_taken")
  status        ViolationStatus   @default(OPEN)
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@map("policy_violations")
}

model FeedEvent {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  userId     String?  @map("user_id")
  type       String
  category   String
  title      String
  description String?
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  actions    String[] @default([])
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("feed_events")
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  before     Json?    @map("before")
  after      Json?    @map("after")
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("audit_logs")
}
