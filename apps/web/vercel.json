{
  "framework": "nextjs",
  "buildCommand": "npx turbo build --filter=web...",
  "outputDirectory": ".next",
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://gon-api.onrender.com/api/v1/:path*"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "https://gon-api.onrender.com"
  }
}
